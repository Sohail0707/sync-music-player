# Copy to `.env` for local `netlify dev`, and set these in the Netlify dashboard for prod.

# --- LiveKit Cloud (sync/control channel) ---
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=your-long-secret-here
LIVEKIT_URL=wss://your-project.livekit.cloud

# --- Host gate: only people with this password can host a party ---
SMP_HOST_PASSWORD=choose-a-strong-password

# --- Cloudflare R2 (music file storage, S3-compatible) ---
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET=smp-music
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
